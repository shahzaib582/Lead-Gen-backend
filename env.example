# Server
PORT=3000
NODE_ENV=development
# Optional: full origin for startup logs (Swagger / health URLs). Defaults to http://localhost:$PORT
# Example production: PUBLIC_BASE_URL=https://leadgen-api-xct7.onrender.com
# PUBLIC_BASE_URL=https://api.example.com

# Comma-separated allowed browser origins (required when using cookies / credentials).
# Example: CORS_ORIGIN=http://localhost:8080,http://localhost:5173
CORS_ORIGIN=http://localhost:8080
# Development only: echo any request Origin (cannot use * with credentials:true).
# Never enable on production. Lets Swagger on another port, or unknown localhost ports, work locally.
# CORS_DEV_ALLOW_ANY=1

# Behind reverse proxy (Render, nginx): set to 1 so rate limits and req.ip use client address.
TRUST_PROXY=1

# Supabase (PostgreSQL only — NOT Supabase Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public bucket for profile images (JPEG/PNG/WebP, max 10 MB via API). Create in Supabase Storage.
SUPABASE_STORAGE_BUCKET=lead_generation_bucket

# JWT — Access Token (short-lived, 15 min)
JWT_ACCESS_SECRET=your-very-long-random-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# JWT — Refresh Token (long-lived, stored in DB)
JWT_REFRESH_EXPIRES_DAYS=7

# Legacy (still read as fallback for JWT_ACCESS_SECRET)
JWT_SECRET=your-very-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Bcrypt work factor for password hashing (10–14). Default 10 balances speed and security.
# BCRYPT_ROUNDS=10

OTP_EXPIRY_MINUTES=10
# Extra minutes added to DB expiry (not shown in email) for Brevo delivery delay.
OTP_EMAIL_BUFFER_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=5
OTP_RESEND_WINDOW_MINUTES=60

# Brevo — transactional email for OTP (signup, verify, password reset)
# Create an API key: Brevo → SMTP & API → API keys. Verify sender email in Brevo → Senders.
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
BREVO_SENDER_NAME=Lead Gen
# Optional display name fallback: APP_NAME=Lead Gen

# OpenAI (mail template generation / workers)
OPENAI_API_KEY=sk-your-openai-key

# Google OAuth (Gmail + Calendar for sending mail and booking Lead Gen meetings)
# Enable Google Calendar API in Cloud Console. Users must reconnect after adding calendar scopes.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Redis / BullMQ (also used for campaign SSE pub/sub; web + workers need the same Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Optional full URL (overrides host/port when set), e.g. redis://:password@host:6379
# REDIS_URL=

# Random delay between sequential campaign email sends (worker + large manual batches).
# Defaults 180000–300000 ms (3–5 minutes).
# MAIL_DELAY_MIN_MS=180000
# MAIL_DELAY_MAX_MS=300000

# Manual run: leads at or below this count send with a short gap (fast batch), not 3–5 min delays.
# MANUAL_RUN_INSTANT_MAX_LEADS=15
# MANUAL_RUN_SMALL_BATCH_GAP_MS=2000
# Show progress banner when lead count is at or above this threshold.
# MANUAL_RUN_BANNER_MIN_LEADS=6

# When 1 or true: POST /api/campaigns with status active and target_leads > 0 auto-assigns leads after create.
# CAMPAIGN_ACTIVE_CREATE_AUTO_ASSIGN=

# BullMQ workers: in production the web process does NOT start workers by default (Render runs separate worker dynos).
# Set to 1 for local dev when you want workers in the same process as the API.
# RUN_WORKERS_IN_WEB=1

# Follow-up scheduler (BullMQ repeatable job). Cron pattern for scanning due follow-ups (default every 6 hours).
# FOLLOW_UP_CRON=0 */6 * * *

# Firebase Cloud Messaging (web push) — optional; in-app notifications work without these.
# Firebase Console → Project settings → Service accounts → Generate new private key.
# Also enable Cloud Messaging API; add a Web app and use its config in the frontend (not these vars).
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Deep link when user clicks a notification (defaults to first CORS_ORIGIN origin).
# FRONTEND_URL=http://localhost:8080

# Stripe billing (optional until paid plans are enabled)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# After creating Products/Prices in Stripe Dashboard, set stripe_price_id on growth/pro rows in plans table.

# Optional plain-text body for auto-created Gmail thank-you drafts when a lead replies (not auto-sent).
# Supports {{firstName}}, {{fullName}}, {{email}}, {{senderName}}.
# THANK_YOU_DRAFT_BODY=Hi {{firstName}},\n\nThank you for your reply.\n\nBest,\n{{senderName}}
