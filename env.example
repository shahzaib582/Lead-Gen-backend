# Server
PORT=3000
NODE_ENV=development

# Supabase (PostgreSQL only — NOT Supabase Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT — Access Token (short-lived, 15 min)
JWT_ACCESS_SECRET=your-very-long-random-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# JWT — Refresh Token (long-lived, stored in DB)
JWT_REFRESH_EXPIRES_DAYS=7

# Legacy (still read as fallback for JWT_ACCESS_SECRET)
JWT_SECRET=your-very-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=5
OTP_RESEND_WINDOW_MINUTES=60

# Email (SMTP / Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Auth System <noreply@yourdomain.com>"

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
